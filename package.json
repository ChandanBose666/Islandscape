{
  "name": "astro-island-visualizer",
  "displayName": "Astro Island Visualizer",
  "description": "Visualize Astro island hydration costs, dependencies, and optimization opportunities directly in your editor.",
  "version": "0.1.0",
  "publisher": "ChandanBose",
  "icon": "assets/Islandscape Icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChandanBose666/Islandscape"
  },
  "bugs": {
    "url": "https://github.com/ChandanBose666/Islandscape/issues"
  },
  "homepage": "https://github.com/ChandanBose666/Islandscape#readme",
  "keywords": [
    "astro",
    "islands",
    "hydration",
    "performance",
    "bundle size",
    "visualization",
    "dependency graph",
    "webdev"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "workspaceContains:**/astro.config.*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "astroIslands",
          "title": "Astro Islands",
          "icon": "$(map)"
        }
      ]
    },
    "views": {
      "astroIslands": [
        {
          "type": "webview",
          "id": "astroIslands.islandMap",
          "name": "Island Map"
        }
      ]
    },
    "commands": [
      {
        "command": "astroIslands.analyzeFile",
        "title": "Astro Islands: Analyze Current File"
      },
      {
        "command": "astroIslands.analyzeWorkspace",
        "title": "Astro Islands: Analyze Workspace"
      },
      {
        "command": "astroIslands.jumpToLargest",
        "title": "Astro Islands: Jump to Largest Island"
      },
      {
        "command": "astroIslands.exportReport",
        "title": "Astro Islands: Export Report"
      }
    ],
    "configuration": {
      "title": "Astro Island Visualizer",
      "properties": {
        "astroIslands.eagerSizeThresholdKB": {
          "type": "number",
          "default": 50,
          "description": "Islands larger than this (gzipped KB) using client:load will trigger a warning."
        },
        "astroIslands.budgets": {
          "type": "object",
          "default": {},
          "description": "Per-route JS budget in KB. Keys are route patterns (e.g. '/product/*'). Status bar turns red when exceeded.",
          "additionalProperties": {
            "type": "number"
          }
        }
      }
    },
    "walkthroughs": [
      {
        "id": "astroIslands.gettingStarted",
        "title": "Get started with Astro Island Visualizer",
        "description": "Learn how to visualize island hydration costs and optimize your Astro project's performance.",
        "steps": [
          {
            "id": "astroIslands.step1",
            "title": "See inline cost annotations",
            "description": "Open any `.astro` file. Colour-coded CodeLens annotations appear above every hydrated island showing directive, framework, and gzip size.\n\n[Open an Astro file](command:workbench.action.quickOpen)",
            "media": {
              "markdown": "walkthrough/step1.md"
            },
            "completionEvents": [
              "onCommand:astroIslands.analyzeFile"
            ]
          },
          {
            "id": "astroIslands.step2",
            "title": "Explore the Island Map sidebar",
            "description": "Open the Island Map panel to see the dependency graph, page view, and global impact dashboard.\n\n[Open Island Map](command:astroIslands.islandMap.focus)",
            "media": {
              "markdown": "walkthrough/step2.md"
            },
            "completionEvents": [
              "onView:astroIslands.islandMap"
            ]
          },
          {
            "id": "astroIslands.step3",
            "title": "Fix islands with one click",
            "description": "Use the Problems tab or inline lightbulbs to convert directives or remove unused hydration.\n\n[Open Problems](command:workbench.actions.view.problems)",
            "media": {
              "markdown": "walkthrough/step3.md"
            },
            "completionEvents": [
              "onCommand:astroIslands.exportReport"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "compile": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^20.0.0",
    "@types/vscode": "1.85.0",
    "@vscode/extension-telemetry": "^1.5.1",
    "@vscode/vsce": "^2.22.0",
    "cytoscape": "^3.33.1",
    "lit": "^3.3.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@astrojs/compiler": "^2.3.0",
    "@vue/compiler-sfc": "^3.5.32",
    "es-module-lexer": "^1.4.1",
    "esbuild": "^0.20.0",
    "svelte": "^5.55.1",
    "tsconfig-paths": "^4.2.0"
  }
}
