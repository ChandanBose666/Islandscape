# VSCode/test tooling
.vscode/**
.vscode-test/**

# Source — compiled to out/ by esbuild
src/**
webview-ui/**

# Config & tooling
.github/**
tsconfig*.json
esbuild.config.js
.eslintrc*
.eslintignore

# Exclude all node_modules by default, then whitelist runtime deps below.
# These packages are marked external in esbuild (not bundled into out/extension.js)
# so they MUST be present in the VSIX node_modules at runtime.
node_modules/**

# @astrojs/compiler — WASM-based parser, cannot be bundled by esbuild
!node_modules/@astrojs/compiler/**

# svelte/compiler — dynamically required for SFC size estimation
!node_modules/svelte/**

# @vue/compiler-sfc and its peer deps — dynamically required for Vue SFC estimation
!node_modules/@vue/compiler-sfc/**
!node_modules/@vue/compiler-core/**
!node_modules/@vue/compiler-dom/**
!node_modules/@vue/compiler-ssr/**
!node_modules/@vue/shared/**
!node_modules/estree-walker/**
!node_modules/magic-string/**
!node_modules/postcss/**
!node_modules/source-map-js/**

# Source maps (comment out to keep for debugging)
out/**/*.map

# Misc
*.vsix
.gitignore
.gitattributes
